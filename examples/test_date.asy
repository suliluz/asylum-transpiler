import "std/sys.asy";

print("Current Date/Time from System:\n");

print("Year (20xx): ");
print_num(sys_year);
print(10);

print("Month: ");
print_num(sys_month);
print(10);

print("Day: ");
print_num(sys_day);
print(10);

print("Time: ");
print_num(sys_hour);
print(58); // :
print_num(sys_minute);
print(58); // :
print_num(sys_second);
print(10);
